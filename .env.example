# PDF Presenter Environment Configuration
# Copy this file to .env and modify as needed

# Server port (default: 3000)
PORT=3000

# Node environment (development/production)
NODE_ENV=production

# Session time-to-live in hours (default: 4)
SESSION_TTL=4

# Maximum file upload size in MB (default: 100)
MAX_FILE_SIZE=100

# Rate limiting window in minutes (default: 60)
RATE_LIMIT_WINDOW=60

# Maximum requests per window (default: 20)
RATE_LIMIT_MAX=20
